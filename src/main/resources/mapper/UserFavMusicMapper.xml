<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.beyond.beatbuddy.music.mapper.UserFavMusicMapper">

    <resultMap id="UserFavMusicResultMap" type="com.beyond.beatbuddy.music.entity.UserFavMusic">
        <id     property="favId"     column="fav_id"/>
        <result property="userId"    column="user_id"/>
        <result property="musicId"   column="music_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO user_fav_music (user_id, music_id)
        VALUES (#{userId}, #{musicId})
    </insert>

    <delete id="deleteByUserIdAndMusicId">
        DELETE FROM user_fav_music
        WHERE user_id = #{userId}
          AND music_id = #{musicId}
    </delete>

    <select id="findByUserId" resultMap="UserFavMusicResultMap">
        SELECT * FROM user_fav_music
        WHERE user_id = #{userId}
        ORDER BY created_at ASC
    </select>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM user_fav_music WHERE user_id = #{userId}
    </select>

</mapper>
