<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.beyond.beatbuddy.taste.mapper.UserProfileMapper">

    <resultMap id="UserProfileResultMap" type="com.beyond.beatbuddy.taste.entity.UserProfile">
        <id     property="userId"    column="user_id"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- MariaDB VECTOR(8) 타입: VEC_FromText('[v1,v2,...,v8]') 형식으로 삽입 -->
    <insert id="upsert">
        INSERT INTO user_profiles (user_id, taste_vector)
        VALUES (#{userId}, VEC_FromText(#{tasteVectorStr}))
        ON DUPLICATE KEY UPDATE
            taste_vector = VEC_FromText(#{tasteVectorStr})
    </insert>

    <select id="findByUserId" resultMap="UserProfileResultMap">
        SELECT user_id, updated_at FROM user_profiles WHERE user_id = #{userId}
    </select>

</mapper>
