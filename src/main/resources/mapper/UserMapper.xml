<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.beyond.beatbuddy.auth.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.beyond.beatbuddy.auth.entity.User">
        <id     property="userId"          column="user_id"/>
        <result property="email"           column="email"/>
        <result property="password"        column="password"/>
        <result property="kakaoId"         column="kakao_id"/>
        <result property="nickname"        column="nickname"/>
        <result property="gender"          column="gender"/>
        <result property="birthYear"       column="birth_year"/>
        <result property="profileImageUrl" column="profile_image_url"/>
        <result property="isTutorialViewed" column="is_tutorial_viewed"/>
        <result property="isTasteAnalyzed" column="is_taste_analyzed"/>
        <result property="status"          column="status"/>
        <result property="allowPushChat"   column="allow_push_chat"/>
        <result property="allowPushSocial" column="allow_push_social"/>
        <result property="refreshToken"    column="refresh_token"/>
        <result property="createdAt"       column="created_at"/>
        <result property="updatedAt"       column="updated_at"/>
    </resultMap>

    <insert id="insertUser" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO users (email, password, kakao_id, nickname, gender, birth_year,
                           profile_image_url, is_tutorial_viewed, is_taste_analyzed,
                           status, allow_push_chat, allow_push_social)
        VALUES (#{email}, #{password}, #{kakaoId}, #{nickname}, #{gender}, #{birthYear},
                #{profileImageUrl}, false, false, 'ACTIVE', true, true)
    </insert>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT * FROM users WHERE email = #{email} AND status = 'ACTIVE'
    </select>

    <select id="findById" resultMap="UserResultMap">
        SELECT * FROM users WHERE user_id = #{userId} AND status = 'ACTIVE'
    </select>

    <update id="updateRefreshToken">
        UPDATE users SET refresh_token = #{refreshToken} WHERE user_id = #{userId}
    </update>

    <update id="deleteRefreshToken">
        UPDATE users SET refresh_token = NULL WHERE user_id = #{userId}
    </update>

</mapper>
